# Production / custom API (optional). Example: https://api.yourdomain.com/api
# VITE_API_BASE=https://example.com/api

# Optional: WebSocket URL if API is not on default port (default: ws://127.0.0.1:3000 in composables)
# VITE_WS_URL=wss://api.example.com

# Optional local/dev bearer token for protected mutation routes.
# Example only — set this in a local .env file, not in git.
# VITE_API_BEARER_TOKEN=stock-trader-sim-dev-token

# Supabase client auth
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Compatibility aliases if you already copied values from a Next.js starter
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
