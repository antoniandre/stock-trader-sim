# Rename this file to .env in this same directory (`api/`) and fill your credentials.
# The server loads `api/.env` by path (not the shell cwd), so values here always apply.
ALPACA_KEY=your_key
ALPACA_SECRET=your_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_STREAM=wss://stream.data.alpaca.markets/v2/iex
SIMULATION=true

# Crypto BUY on Alpaca: non-USD quotes (e.g. AAVE/USDC) need wallet balances for that stablecoin.
# Default `paper`: on Alpaca paper only, route BUY to BASE/USD when listed so USD buying power is used.
# `always` = also on live (same routing). `off` = never rewrite symbol.
CRYPTO_USD_QUOTE_FALLBACK=paper

# Optional dev/pro token for mutation routes.
# When set, POST /api/orders and DELETE /api/orders/:orderId require:
# Authorization: Bearer <token>
API_BEARER_TOKEN=change-me

# Auth (API verifies `Authorization: Bearer` from the SPA)
# - off: no user on requests; /api/me returns 401 unless using API_BEARER_TOKEN-only flows.
# - mock: every request gets DEV_AUTH_* (sidebar shows "Dev User" — for local UI only).
# - provider: verify JWT (set AUTH_PROVIDER=supabase + secrets below for Supabase Auth).
AUTH_MODE=off
AUTH_PROVIDER=mock
AUTH_JWT_SECRET=
# For Supabase, issuer/audience default from SUPABASE_URL when unset (see api/config.js).
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
SUPABASE_URL=
# Supabase Dashboard → Project Settings → API → JWT Signing Keys → copy the secret
# used to verify access tokens (often labeled "JWT Secret" / legacy HS256 secret).
# Required when AUTH_MODE=provider and AUTH_PROVIDER=supabase.
SUPABASE_JWT_SECRET=
# Used only when AUTH_MODE=mock
DEV_AUTH_USER_ID=dev-user
DEV_AUTH_EMAIL=dev@example.com
DEV_AUTH_NAME=Dev User
DEV_AUTH_PLAN=pro

# Feature flags (defaults shown)
FEATURE_LIVE_TRADING=true
FEATURE_PAPER_TRADING=true
FEATURE_MARKET_ORDERS=true
FEATURE_LIMIT_ORDERS=false
FEATURE_STOP_ORDERS=false
FEATURE_API_ACCESS=false
FEATURE_ALERTS=false
FEATURE_BOTS=false
