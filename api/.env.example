# Rename this file to .env and fill your credentials
ALPACA_KEY=your_key
ALPACA_SECRET=your_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_STREAM=wss://stream.data.alpaca.markets/v2/iex
SIMULATION=true

# Crypto BUY on Alpaca: non-USD quotes (e.g. AAVE/USDC) need wallet balances for that stablecoin.
# Default `paper`: on Alpaca paper only, route BUY to BASE/USD when listed so USD buying power is used.
# `always` = also on live (same routing). `off` = never rewrite symbol.
CRYPTO_USD_QUOTE_FALLBACK=paper

# Optional dev/pro token for mutation routes.
# When set, POST /api/orders and DELETE /api/orders/:orderId require:
# Authorization: Bearer <token>
API_BEARER_TOKEN=change-me

# Auth scaffolding
# For Supabase email/password auth, set AUTH_MODE=provider, AUTH_PROVIDER=supabase,
# SUPABASE_URL, and SUPABASE_JWT_SECRET.
AUTH_MODE=off
AUTH_PROVIDER=mock
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
SUPABASE_URL=
SUPABASE_JWT_SECRET=
DEV_AUTH_USER_ID=dev-user
DEV_AUTH_EMAIL=dev@example.com
DEV_AUTH_NAME=Dev User
DEV_AUTH_PLAN=pro

# Feature flags (defaults shown)
FEATURE_LIVE_TRADING=true
FEATURE_PAPER_TRADING=true
FEATURE_MARKET_ORDERS=true
FEATURE_LIMIT_ORDERS=false
FEATURE_STOP_ORDERS=false
FEATURE_API_ACCESS=false
FEATURE_ALERTS=false
FEATURE_BOTS=false
